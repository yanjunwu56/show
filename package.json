{
  "name": "admin-monorepo",
  "private": true,
  "workspaces": [
    "vue3-admin",
    "react-admin",
    "packages/*"
  ],
  "scripts": {
    "dev:vue": "npm run dev -w vue3-admin",
    "dev:react": "npm run dev -w react-admin",
    "build": "node scripts/run-workspaces.mjs build",
    "lint": "node scripts/run-workspaces.mjs lint",
    "format": "node scripts/run-workspaces.mjs format",
    "turbo:build": "turbo run build",
    "turbo:lint": "turbo run lint",
    "turbo:format": "turbo run format",
    "turbo:dev": "turbo run dev --parallel",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "commitlint": "commitlint --edit",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "turbo": "^2.8.20"
  }
}
